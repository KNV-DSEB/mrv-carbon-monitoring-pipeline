# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- Google Earth Engine ---
# Project id of the Google Cloud project registered for Earth Engine access.
# See docs/setup/gee_setup.md for how to create this.
GEE_PROJECT_ID=

# Path to the GEE service account JSON key (keep it outside the repo, e.g.
# in a secrets folder, and point this at its absolute path).
GEE_SERVICE_ACCOUNT_KEY_PATH=

# --- Pipeline config ---
# GeoJSON file defining the current area of interest, relative to repo root.
AOI_PATH=data/external/aoi/bac_ninh_pilot.geojson

# Sentinel-2 query window. These are seasonal placeholder defaults for the
# pilot (approximate Vụ Mùa season in the Red River Delta), NOT
# authoritative truth — verify against the actual local crop calendar
# before a real run and adjust as needed.
DATE_START=2026-06-15
DATE_END=2026-11-15

# Scene-level cloud cover filter threshold (%). Applied at query time,
# before the per-pixel SCL cloud mask.
MAX_CLOUD_COVER_PCT=70

# --- Features config ---
# Minimum manifest aoi_clear_fraction (0-1) for a scene to be included
# when computing spectral indices in the features module.
MIN_CLEAR_FRACTION=0.8

# Comma-separated list of spectral indices to compute (see
# src/mrv/features/indices.py for supported names).
FEATURE_INDICES=ndvi,ndwi,lswi

# --- Sentinel-1 SAR config (spec 07) ---
# Orbit lock for the SAR series. ASCENDING/DESCENDING passes and different
# relative orbits image the AOI at different incidence angles, so their
# backscatter is NOT comparable across dates — the SAR series must lock to ONE
# pass + ONE relative orbit. Run `python -m mrv.pipeline.recon_sar` FIRST (with
# these unset) to see the orbit distribution over your window, then set both and
# re-run. Leave unset for optical-only runs — they are ignored there.
# S1_ORBIT_PASS=DESCENDING
# S1_RELATIVE_ORBIT=

# --- AWS (phase 2 — leave unset until cloud budget is confirmed) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
